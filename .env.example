# Moodle Configuration
PHP_VERSION=8.4
MOODLE_VERSION=5.1.3
MOODLE_MAJOR_VERSION=501
MOODLE_URL=http://localhost

# Database Configuration
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASS=moodle_secure_pass

# Initial Admin Credentials (REQUIRED for first boot, remove afterwards)
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=Admin123!
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_SITE_FULLNAME="Moodle Site"
MOODLE_SITE_SHORTNAME="Moodle"

# Upgrade & Maintenance
MOODLE_AUTO_UPGRADE=false
MOODLE_DISABLE_INSTALL=false
MOODLE_CRON_COUNT=1
MOODLE_ADHOC_TASK_COUNT=0

# Forced Configuration (UI will show these as locked)
MOODLE_CFG_theme=boost
MOODLE_CFG_lang=en

# Email Configuration
MOODLE_SMTP_HOSTS=smtp.example.com:587
MOODLE_SMTP_SECURE=tls
MOODLE_SMTP_USER=user@example.com
MOODLE_SMTP_PASS=password
MOODLE_NOREPLY_ADDRESS=noreply@example.com

# Automated OAuth2 Issuer (JSON)
# MOODLE_OAUTH2_CONFIG_JSON='{"name":"MyIDP","baseurl":"https://idp.example.com","clientid":"id","clientsecret":"secret","enabled":1,"field_mappings":{"sub":"username","email":"email"}}'

# Proxy Settings
MOODLE_REVERSE_PROXY=false
MOODLE_SSL_PROXY=false
